# Database - UPDATE THIS WITH YOUR LOCAL DATABASE
DATABASE_URL="postgresql://username:password@localhost:5432/tutroid_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_ISSUER="tutroid"
JWT_AUDIENCE="tutroid-users"

# Server
PORT=5000
NODE_ENV=development

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR="./storage/materials"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SIGNUP_RATE_LIMIT=50
FORGOT_PASSWORD_RATE_LIMIT=15
OTP_RATE_LIMIT=15
