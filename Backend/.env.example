# Database
DATABASE_URL="postgresql://username:password@localhost:5432/tutroid_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_ISSUER="tutroid"
JWT_AUDIENCE="tutroid-users"

# Server
PORT=5000
NODE_ENV=development

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR="./storage/materials"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Brevo Configuration (Using API instead of SMTP for better cloud compatibility)
SENDER_EMAIL=your-sender-email@example.com
BREVO_API_KEY=your-brevo-api-key-here
# Legacy SMTP credentials (kept for reference, but API is preferred)
SMTP_USER=your-brevo-smtp-login
SMTP_PASSWORD=your-brevo-smtp-password-here
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587

# Rate limiting configuration
SIGNUP_RATE_LIMIT=50
FORGOT_PASSWORD_RATE_LIMIT=15
OTP_RATE_LIMIT=15

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100