# Database
DATABASE_URL="postgresql://username:password@localhost:5432/tutroid_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_ISSUER="tutroid"
JWT_AUDIENCE="tutroid-users"

# Server
PORT=5000
NODE_ENV=development

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR="./storage/materials"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Brevo SMTP Configuration
SENDER_EMAIL=kumargg1113@gmail.com
SMTP_USER=94fd1c001@smtp-brevo.com
SMTP_PASSWORD=your-brevo-smtp-password-here
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587

# Rate limiting configuration
SIGNUP_RATE_LIMIT=50
FORGOT_PASSWORD_RATE_LIMIT=15
OTP_RATE_LIMIT=15

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100